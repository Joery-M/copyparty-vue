{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "singleQuote": true,
  "tabWidth": 4,
  "useTabs": false,
  "trailingComma": "none",
  "sortPackageJson": true,
  "ignorePatterns": ["pnpm-lock.yaml", "pnpm-workspace.yaml", "src/components/ui"],
  "overrides": [
    {
      "files": ["*.json"],
      "options": {
        "tabWidth": 2
      }
    }
  ]
}
